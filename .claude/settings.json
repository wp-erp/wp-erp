      "Edit(.env)",
      "Edit(.env.*)",
      "Write(composer.lock)",
      "Edit(composer.lock)",
      "Write(package-lock.json)",
      "Edit(package-lock.json)",
      "Write(wp-erp.php)",
      "Write(readme.txt)",
      "Write(vendor/**)",
      "Edit(vendor/**)",
      "Write(node_modules/**)",
      "Edit(node_modules/**)",
      "Write(build/**)",
      "Write(assets/**)",
      "Write(i18n/languages/*.mo)",
