      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(composer phpcs:*)",
      "Bash(composer phpcbf:*)",
      "Bash(composer phpcsf:*)",
      "Bash(composer validate:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(./vendor/bin/phpcs:*)",
      "Bash(./vendor/bin/phpcbf:*)",
      "Bash(./vendor/bin/codecept:*)",
