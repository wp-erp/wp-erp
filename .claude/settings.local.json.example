{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy to settings.local.json (gitignored). Use for personal allow/deny overrides — e.g. your local wp-cli paths, MAMP php binary, etc.",
  "permissions": {
    "allow": [
      "Bash(/Applications/MAMP/bin/php/php8.3.0/bin/php:*)",
      "Bash(wp:*)"
    ]
  }
}
