# ──────────────────────────────────────────────────────────────────────────
# WP ERP — Playwright suite config. Copy to `.env` and adjust.
# Two modes:  WP_ENV=true  -> wp-env/Docker (default; web 9999 dev / 9989 tests; the
#                              MySQL host port is auto-assigned and written into .env
#                              by `npm run start:env` / `npm run db:port`)
#             WP_ENV=false -> run against an existing site (e.g. Valet) — see VALET block
# NEVER put real credentials or a real LICENSE_KEY in this file — it is committed.
# ──────────────────────────────────────────────────────────────────────────

# Admin (wp-env default admin credentials)
ADMIN=admin
ADMIN_PASSWORD=password
ADMIN_EMAIL=wordpress@example.com

# Test users (one per WP ERP role; created by the auth setup)
HR_MANAGER=hr_manager1
CRM_MANAGER=crm_manager1
ACC_MANAGER=acc_manager1
EMPLOYEE=employee1
USER_PASSWORD=01erp01

# WP ERP configuration
#   ERP_PRO=false -> lite run (free wp-erp only).
#   ERP_PRO=true  -> pro run: requires the erp-pro plugin present (sibling dir, see
#                    .wp-env.json) AND a valid license. Put your real key in .env only.
ERP_PRO=false
LICENSE_KEY=
# Pro license activation (read by the @pro site-setup step). Fill in .env only.
ERP_PRO_EMAIL=
ERP_PRO_SUBSCRIPTION=yearly

# Playwright
BASE_URL=http://localhost:9999
HEADLESS=false
CI=false
NO_SETUP=false
SLOWMO=0

# Environment provider
WP_ENV=true
WP_ROOT=

# Database — the wp-env DEVELOPMENT site (web port 9999) is backed by DB "wordpress".
# wp-env auto-assigns the MySQL HOST port on each (re)create; `npm run start:env`
# (and `npm run db:port`) writes the live value into DB_PORT below — so you normally
# never touch it. The placeholder is only a fallback. Use "tests-wordpress" only if
# you point BASE_URL at the wp-env tests site instead.
DB_HOST_NAME=127.0.0.1
DB_USER_NAME=root
DB_USER_PASSWORD=password
DATABASE=wordpress
DB_PORT=9998
DB_PREFIX=wp

# REST (?rest_route= form is permalink-safe; use BASE_URL/wp-json for pretty permalinks)
SERVER_URL=http://localhost:9999/wp-json
X_WP_NONCE=

# ── Seeded IDs — auto-populated by the setup chain (leave blank) ──────────────
EMPLOYEE_ID=
DEPARTMENT_ID=
DESIGNATION_ID=
LEAVE_POLICY_ID=
HOLIDAY_ID=
CONTACT_ID=
CRM_COMPANY_ID=
CUSTOMER_ID=
VENDOR_ID=
INVOICE_ID=
ACCT_PRODUCT_ID=

# ── Existing-site / Valet override (uncomment & set WP_ENV=false) ─────────────
# Run against any local WordPress that has wp-erp installed (no Docker). Replace
# the placeholders with your own site's values; a local `wp` (wp-cli) must be on PATH.
# WP_ENV=false
# BASE_URL=https://yoursite.test
# SERVER_URL=https://yoursite.test/?rest_route=
# WP_ROOT=/path/to/your/wordpress
# ADMIN=admin
# ADMIN_PASSWORD=your-password
# DB_HOST_NAME=localhost
# DB_USER_NAME=root
# DB_USER_PASSWORD=root
# DATABASE=your_db_name
# DB_PORT=3306
