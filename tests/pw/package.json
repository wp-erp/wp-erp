{
  "name": "wp-erp-pw",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright (TypeScript) E2E + REST suite for WP ERP (free + pro), Dokan-style framework.",
  "license": "GPL-2.0-or-later",
  "author": "weDevs",
  "homepage": "https://wperp.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/wp-erp/wp-erp.git",
    "directory": "tests/pw"
  },
  "bugs": {
    "url": "https://github.com/wp-erp/wp-erp/issues"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "install:chromium": "playwright install chromium",
    "start:env": "wp-env start || wp-env start || wp-env start",
    "poststart:env": "node ./bin/syncDbPort.js",
    "stop:env": "wp-env stop",
    "reset:env": "wp-env destroy && wp-env start && node ./bin/syncDbPort.js",
    "db:port": "node ./bin/syncDbPort.js",
    "create:admin": "node ./bin/createAdmin.js",
    "test": "playwright test",
    "test:e2e": "NO_SETUP=true playwright test --project=e2e_tests",
    "test:api": "playwright test --config=api.config.ts",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "type:check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write"
  },
  "dependencies": {
    "@faker-js/faker": "^9.4.0",
    "@playwright/test": "^1.57.0",
    "@wordpress/env": "^10.20.0",
    "dotenv": "^16.4.7",
    "mysql2": "^3.12.0",
    "php-serialize": "^5.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/php-serialize": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^1.8.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
