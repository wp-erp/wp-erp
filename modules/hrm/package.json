{
  "name": "wp-erp-hrm",
  "version": "1.13.5",
  "private": true,
  "description": "WP-ERP HR module React 19 admin redesign — module-scoped build (free).",
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0"
  },
  "scripts": {
    "dev": "wp-scripts start --config webpack.react.config.js",
    "build": "wp-scripts build --config webpack.react.config.js",
    "build:types": "tsc --emitDeclarationOnly --outDir assets/dist-react/types",
    "lint": "wp-scripts lint-js assets/src-react",
    "lint:style": "wp-scripts lint-style 'assets/src-react/**/*.css'",
    "format": "wp-scripts format assets/src-react",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@wedevs/plugin-ui": "github:getdokan/plugin-ui",
    "@wordpress/api-fetch": "^7.32.0",
    "@wordpress/components": "^30.5.0",
    "@wordpress/data": "^10.32.0",
    "@wordpress/dataviews": "^10.2.0",
    "@wordpress/date": "^5.32.0",
    "@wordpress/dom-ready": "^4.32.0",
    "@wordpress/element": "^6.32.0",
    "@wordpress/hooks": "^4.32.0",
    "@wordpress/i18n": "^6.5.0",
    "@wordpress/notices": "^5.32.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^2.5.5",
    "clsx": "^2.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^6.32.0",
    "@wordpress/scripts": "^30.25.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
