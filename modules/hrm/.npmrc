# Module-scoped npm config for the React 19 build.
#
# legacy-peer-deps: required because every @wordpress/* package on the public
# registry still declares `peerDependencies: { react: '^18.0.0' }`. The redesign
# pins React 19 per design.md "Decision: React 19 as the UI framework".
# React 19 is runtime-compatible with the component shapes these packages ship;
# the peer mismatch is purely advisory. Dokan ships the same configuration.
legacy-peer-deps=true

# --- pnpm (React build, Node 24) ---
# node-linker=hoisted: write a flat node_modules so the wp-scripts/webpack
# toolchain resolves deps exactly as it did under npm (no symlink-store surprises).
# strict-peer-dependencies=false: pnpm equivalent of npm legacy-peer-deps above —
# the @wordpress/* + @wedevs/plugin-ui react ^18 peer vs our React 19 is advisory.
node-linker=hoisted
strict-peer-dependencies=false
