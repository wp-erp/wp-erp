# Normalize line endings to LF for all text files (matches project's original LF style).
* text=auto eol=lf

# Explicitly treat common source/text types as LF.
*.php   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.vue   text eol=lf
*.css   text eol=lf
*.less  text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.pot   text eol=lf
*.po    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf

# Binary files: never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.mo    binary
