# Normalize line endings to LF for all text files (matches project's original LF style).
* text=auto eol=lf

# Explicitly treat common source/text types as LF.
*.php   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.vue   text eol=lf
*.css   text eol=lf
*.less  text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.pot   text eol=lf
*.po    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf

# Generated build artifacts — kept tracked for the AppSero release, but collapsed
# in `git diff` and marked generated in GitHub PR review so they stop polluting
# code review. (React dist-react is gitignored in dev and force-added at release.)
*.min.js                          -diff linguist-generated
*.min.css                         -diff linguist-generated
*-rtl.css                         -diff linguist-generated
modules/hrm/assets/dist-react/**  -diff linguist-generated

# Binary files: never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.mo    binary
